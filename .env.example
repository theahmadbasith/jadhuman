# ─── Firebase ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Enkripsi ────────────────────────────────────────────────────
# Kunci AES untuk enkripsi credential di Firestore (pakai di sisi client)
VITE_APP_SECRET=

# Kunci payload layered encryption (Vigenere-like, pakai di sisi client)
VITE_PAYLOAD_KEY=

# ─── Server (Node.js proxy) ───────────────────────────────────────
# Port server Express (default: 3000)
PORT=3000

# IP/hostname server absensi (default: 103.109.206.102)
ABSENSI_BASE_HOST=103.109.206.102

# Origin yang diizinkan akses proxy, pisahkan dengan koma
# Contoh production: https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
